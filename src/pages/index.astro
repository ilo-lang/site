---
// Custom landing page — bypasses Starlight entirely
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>ilo — Token-optimised programming language for AI agents</title>
  <meta name="description" content="0.33x the tokens, 0.22x the characters of Python. Type-verified before execution. The first language designed for AI agents." />
  <meta name="theme-color" content="#f59e0b" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=Instrument+Serif:ital@1&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- NAV -->
  <nav>
    <div class="nav-inner">
      <a href="/" class="nav-logo">ilo</a>
      <div class="nav-links">
        <a href="https://github.com/ilo-lang/ilo" target="_blank" rel="noopener" class="nav-github">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>GitHub
        </a>
        <a href="/docs/introduction/" class="nav-cta">Get Started</a>
      </div>
    </div>
  </nav>

  <main>
    <!-- HERO -->
    <section class="hero">
      <div class="hero-glow"></div>
      <div class="hero-grid"></div>
      <div class="container hero-content">
        <div class="hero-badge">programming language for AI agents</div>
        <h1 class="hero-title">ilo</h1>
        <p class="hero-tagline">
          The first language designed for machines, not people.<br />
          <span class="hero-tagline-accent">0.33&times; the tokens. 0.22&times; the characters. Type-verified before execution.</span>
        </p>
        <div class="install-tabs">
          <div class="tab-buttons">
            <button class="tab-btn active" data-tab="mac">macOS / Linux</button>
            <button class="tab-btn" data-tab="windows">Windows</button>
            <button class="tab-btn" data-tab="claude">Claude Code</button>
          </div>
          <div class="hero-terminal" id="install-cmd">
            <span class="terminal-prompt">$</span>
            <span class="terminal-text" data-cmd="mac">curl -fsSL https://raw.githubusercontent.com/ilo-lang/ilo/main/install.sh | sh</span>
            <span class="terminal-text" data-cmd="windows" style="display:none">irm https://raw.githubusercontent.com/ilo-lang/ilo/main/install.ps1 | iex</span>
            <span class="terminal-text" data-cmd="claude" style="display:none">/plugin marketplace add ilo-lang/ilo && /plugin install ilo-lang/ilo</span>
            <button class="terminal-copy" id="copy-btn" aria-label="Copy install command">
              <svg class="icon-copy" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              <svg class="icon-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="display:none"><polyline points="20 6 9 17 4 12"/></svg>
            </button>
          </div>
        </div>
        <div class="hero-actions">
          <a href="/docs/introduction/" class="btn btn-primary">
            Get Started
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="https://github.com/ilo-lang/ilo" target="_blank" rel="noopener" class="btn btn-outline">
            View on GitHub
          </a>
        </div>
      </div>
    </section>

    <!-- STATS -->
    <section class="stats" data-animate>
      <div class="container stats-grid">
        <div class="stat">
          <div class="stat-number">67%</div>
          <div class="stat-label">fewer tokens</div>
          <div class="stat-context">vs Python</div>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <div class="stat-number">78%</div>
          <div class="stat-label">fewer characters</div>
          <div class="stat-context">vs Python</div>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <div class="stat-number">&check;</div>
          <div class="stat-label">type-verified</div>
          <div class="stat-context">before execution</div>
        </div>
      </div>
    </section>

    <!-- CODE COMPARISON -->
    <section class="comparison" data-animate>
      <div class="container">
        <h2 class="section-title">Same semantics. Fewer tokens.</h2>
        <p class="section-subtitle">A real function. Same logic. See the difference.</p>
        <div class="compare-grid">
          <div class="code-window code-window--muted">
            <div class="code-header">
              <div class="window-dots">
                <span class="dot dot--red"></span>
                <span class="dot dot--yellow"></span>
                <span class="dot dot--green"></span>
              </div>
              <span class="code-filename">total.py</span>
              <span class="code-badge">~30 tokens &middot; 120 chars</span>
            </div>
            <pre class="code-body"><code><span class="syn-kw">def</span> <span class="syn-fn">total</span>(<span class="syn-p">p</span>: <span class="syn-t">float</span>, <span class="syn-p">q</span>: <span class="syn-t">int</span>, <span class="syn-p">r</span>: <span class="syn-t">float</span>) -> <span class="syn-t">float</span>:
    <span class="syn-p">s</span> = <span class="syn-p">p</span> * <span class="syn-p">q</span>
    <span class="syn-p">t</span> = <span class="syn-p">s</span> * <span class="syn-p">r</span>
    <span class="syn-kw">return</span> <span class="syn-p">s</span> + <span class="syn-p">t</span></code></pre>
          </div>
          <div class="code-window code-window--highlight">
            <div class="code-header">
              <div class="window-dots">
                <span class="dot dot--red"></span>
                <span class="dot dot--yellow"></span>
                <span class="dot dot--green"></span>
              </div>
              <span class="code-filename">total.ilo</span>
              <span class="code-badge code-badge--accent">~10 tokens &middot; 38 chars</span>
            </div>
            <pre class="code-body"><code><span class="syn-fn">tot</span> <span class="syn-p">p</span><span class="syn-t">:n</span> <span class="syn-p">q</span><span class="syn-t">:n</span> <span class="syn-p">r</span><span class="syn-t">:n</span><span class="syn-op">&gt;</span><span class="syn-t">n</span>;<span class="syn-p">s</span>=<span class="syn-op">*</span><span class="syn-p">p</span> <span class="syn-p">q</span>;<span class="syn-p">t</span>=<span class="syn-op">*</span><span class="syn-p">s</span> <span class="syn-p">r</span>;<span class="syn-op">+</span><span class="syn-p">s</span> <span class="syn-p">t</span></code></pre>
          </div>
        </div>
      </div>
    </section>

    <!-- FEATURES -->
    <section class="features" data-animate>
      <div class="container">
        <h2 class="section-title">Designed for machines</h2>
        <p class="section-subtitle">Every feature exists to reduce total token cost.</p>
        <div class="feature-grid">

          <div class="feature-card feature-card--wide">
            <div class="feature-label">Syntax</div>
            <h3>Prefix Notation</h3>
            <p>Operators before operands. No parentheses. No precedence ambiguity. 22% fewer tokens, 42% fewer characters vs infix.</p>
            <div class="feature-code">
              <code><span class="syn-op">+*</span><span class="syn-p">a</span> <span class="syn-p">b</span> <span class="syn-p">c</span></code>
              <span class="feature-code-note">(a &times; b) + c</span>
            </div>
          </div>

          <div class="feature-card feature-card--wide">
            <div class="feature-label">Safety</div>
            <h3>Verified Before Execution</h3>
            <p>Every program is type-checked before it runs. Agents get compact error codes, not stack traces. One token, not a paragraph.</p>
            <div class="feature-code feature-code--error">
              <code>ILO-T004: expected n, got t</code>
            </div>
          </div>

          <div class="feature-card">
            <div class="feature-label">Control</div>
            <h3>Guards</h3>
            <p>Flat conditionals. No nesting. No braces.</p>
            <div class="feature-code">
              <code><span class="syn-op">&gt;=</span><span class="syn-p">sp</span> 1000 <span class="syn-s">"gold"</span></code>
            </div>
          </div>

          <div class="feature-card">
            <div class="feature-label">Composition</div>
            <h3>Pipes</h3>
            <p>Chain functions left-to-right.</p>
            <div class="feature-code">
              <code><span class="syn-p">x</span><span class="syn-op">&gt;&gt;</span><span class="syn-fn">dbl</span><span class="syn-op">&gt;&gt;</span><span class="syn-fn">inc</span></code>
            </div>
          </div>

          <div class="feature-card">
            <div class="feature-label">Ergonomics</div>
            <h3>Auto-unwrap !</h3>
            <p>12 tokens down to 1. Error propagation without the ceremony.</p>
            <div class="feature-code">
              <code><span class="syn-fn">inner</span><span class="syn-op">!</span> <span class="syn-p">x</span></code>
            </div>
          </div>

          <div class="feature-card">
            <div class="feature-label">Integrations</div>
            <h3>MCP & HTTP Tools</h3>
            <p>Wire external APIs as typed functions. Type-checked at load time.</p>
            <div class="feature-code">
              <code><span class="syn-op">--</span><span class="syn-p">tools</span> tools.json</code>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- EXAMPLES -->
    <section class="examples" data-animate>
      <div class="container">
        <h2 class="section-title">See it in action</h2>
        <div class="examples-tabs">
          <div class="examples-tab-buttons">
            <button class="examples-tab-btn active" data-example="recursion">Recursion</button>
            <button class="examples-tab-btn" data-example="classification">Classification</button>
            <button class="examples-tab-btn" data-example="pipeline">Data Pipeline</button>
            <button class="examples-tab-btn" data-example="pipes">Pipes</button>
            <button class="examples-tab-btn" data-example="lists">Lists</button>
            <button class="examples-tab-btn" data-example="errors">Error Handling</button>
          </div>
          <div class="examples-panel">
            <div class="example-pane active" data-example-pane="recursion">
              <div class="example-compare">
                <div class="example-version">
                  <div class="example-version-label">Inline</div>
                  <pre class="example-code"><code><span class="syn-dim">$</span> ilo <span class="syn-s">'fac n:n>n;<=n 1 1;r=fac -n 1;*n r'</span> 5
<span class="syn-result">120</span></code></pre>
                </div>
                <div class="example-version">
                  <div class="example-version-label">File</div>
                  <pre class="example-code"><code><span class="syn-fn">fac</span> <span class="syn-p">n</span><span class="syn-t">:number</span> <span class="syn-op">&gt;</span> <span class="syn-t">number</span>
  <span class="syn-op">&lt;=</span> <span class="syn-p">n</span> 1 → return 1
  <span class="syn-p">r</span> = <span class="syn-fn">fac</span> (<span class="syn-op">-</span> <span class="syn-p">n</span> 1)
  <span class="syn-op">*</span> <span class="syn-p">n</span> <span class="syn-p">r</span>
</code></pre>
                  <pre class="example-output"><code><span class="syn-dim">$</span> ilo fac.ilo fac 5
<span class="syn-result">120</span></code></pre>
                </div>
              </div>
              <div class="example-desc">Factorial. Guard as base case, then recurse.</div>
            </div>
            <div class="example-pane" data-example-pane="classification">
              <div class="example-compare">
                <div class="example-version">
                  <div class="example-version-label">Inline</div>
                  <pre class="example-code"><code><span class="syn-dim">$</span> ilo <span class="syn-s">'cls sp:n>t;>=sp 1000 "gold";>=sp 500 "silver";"bronze"'</span> 750
<span class="syn-result">silver</span></code></pre>
                </div>
                <div class="example-version">
                  <div class="example-version-label">File</div>
                  <pre class="example-code"><code><span class="syn-fn">cls</span> <span class="syn-p">sp</span><span class="syn-t">:number</span> <span class="syn-op">&gt;</span> <span class="syn-t">text</span>
  <span class="syn-op">&gt;=</span> <span class="syn-p">sp</span> 1000 → return <span class="syn-s">"gold"</span>
  <span class="syn-op">&gt;=</span> <span class="syn-p">sp</span> 500  → return <span class="syn-s">"silver"</span>
  <span class="syn-s">"bronze"</span>
</code></pre>
                  <pre class="example-output"><code><span class="syn-dim">$</span> ilo cls.ilo cls 750
<span class="syn-result">silver</span></code></pre>
                </div>
              </div>
              <div class="example-desc">Three-tier classifier. Guards fall through &mdash; no if/else needed.</div>
            </div>
            <div class="example-pane" data-example-pane="pipeline">
              <div class="example-compare">
                <div class="example-version">
                  <div class="example-version-label">Inline</div>
                  <pre class="example-code"><code><span class="syn-dim">$</span> ilo <span class="syn-s">'p r:L ?>n;c=flt q r;sum c'</span> <span class="syn-s">'q x:?>b;>x 0'</span> 10,-3,7,-1,4
<span class="syn-result">21</span></code></pre>
                </div>
                <div class="example-version">
                  <div class="example-version-label">File</div>
                  <pre class="example-code"><code><span class="syn-fn">proc</span> <span class="syn-p">rows</span><span class="syn-t">:List</span> <span class="syn-t">?</span> <span class="syn-op">&gt;</span> <span class="syn-t">number</span>
  <span class="syn-p">clean</span> = <span class="syn-fn">filter</span> <span class="syn-fn">pos</span> <span class="syn-p">rows</span>
  <span class="syn-fn">sum</span> <span class="syn-p">clean</span>

<span class="syn-fn">pos</span> <span class="syn-p">x</span><span class="syn-t">:?</span> <span class="syn-op">&gt;</span> <span class="syn-t">bool</span>
  <span class="syn-op">&gt;</span> <span class="syn-p">x</span> 0
</code></pre>
                  <pre class="example-output"><code><span class="syn-dim">$</span> ilo pipeline.ilo proc [10,-3,7,-1,4]
<span class="syn-result">21</span></code></pre>
                </div>
              </div>
              <div class="example-desc">Filter positives and sum. Higher-order functions as first-class builtins.</div>
            </div>
            <div class="example-pane" data-example-pane="pipes">
              <div class="example-compare">
                <div class="example-version">
                  <div class="example-version-label">Inline</div>
                  <pre class="example-code"><code><span class="syn-dim">$</span> ilo <span class="syn-s">'dbl x:n>n;*x 2'</span> <span class="syn-s">'inc x:n>n;+x 1'</span> <span class="syn-s">'rn x:n>n;x>>dbl>>inc'</span> 5
<span class="syn-result">11</span></code></pre>
                </div>
                <div class="example-version">
                  <div class="example-version-label">File</div>
                  <pre class="example-code"><code><span class="syn-fn">dbl</span> <span class="syn-p">x</span><span class="syn-t">:number</span> <span class="syn-op">&gt;</span> <span class="syn-t">number</span>
  <span class="syn-op">*</span> <span class="syn-p">x</span> 2

<span class="syn-fn">inc</span> <span class="syn-p">x</span><span class="syn-t">:number</span> <span class="syn-op">&gt;</span> <span class="syn-t">number</span>
  <span class="syn-op">+</span> <span class="syn-p">x</span> 1

<span class="syn-fn">run</span> <span class="syn-p">x</span><span class="syn-t">:number</span> <span class="syn-op">&gt;</span> <span class="syn-t">number</span>
  <span class="syn-p">x</span> <span class="syn-op">&gt;&gt;</span> <span class="syn-fn">dbl</span> <span class="syn-op">&gt;&gt;</span> <span class="syn-fn">inc</span>
</code></pre>
                  <pre class="example-output"><code><span class="syn-dim">$</span> ilo pipes.ilo run 5
<span class="syn-result">11</span></code></pre>
                </div>
              </div>
              <div class="example-desc">Pipe chains compose functions left-to-right. No nesting to untangle.</div>
            </div>
            <div class="example-pane" data-example-pane="lists">
              <div class="example-compare">
                <div class="example-version">
                  <div class="example-version-label">Inline</div>
                  <pre class="example-code"><code><span class="syn-dim">$</span> ilo <span class="syn-s">'sq x:n>n;*x x'</span> <span class="syn-s">'big x:n>b;>x 10'</span> <span class="syn-s">'kp xs:L n>L n;flt big (map sq xs)'</span> 1,2,3,4,5
<span class="syn-result">16,25</span></code></pre>
                </div>
                <div class="example-version">
                  <div class="example-version-label">File</div>
                  <pre class="example-code"><code><span class="syn-fn">sq</span> <span class="syn-p">x</span><span class="syn-t">:number</span> <span class="syn-op">&gt;</span> <span class="syn-t">number</span>
  <span class="syn-op">*</span> <span class="syn-p">x</span> <span class="syn-p">x</span>

<span class="syn-fn">big</span> <span class="syn-p">x</span><span class="syn-t">:number</span> <span class="syn-op">&gt;</span> <span class="syn-t">bool</span>
  <span class="syn-op">&gt;</span> <span class="syn-p">x</span> 10

<span class="syn-fn">keep</span> <span class="syn-p">xs</span><span class="syn-t">:List number</span> <span class="syn-op">&gt;</span> <span class="syn-t">List number</span>
  <span class="syn-fn">filter</span> <span class="syn-fn">big</span> (<span class="syn-fn">map</span> <span class="syn-fn">sq</span> <span class="syn-p">xs</span>)
</code></pre>
                  <pre class="example-output"><code><span class="syn-dim">$</span> ilo lists.ilo keep [1,2,3,4,5]
<span class="syn-result">[16, 25]</span></code></pre>
                </div>
              </div>
              <div class="example-desc">Square a list, keep values over 10. Higher-order functions as first-class builtins.</div>
            </div>
            <div class="example-pane" data-example-pane="errors">
              <div class="example-compare">
                <div class="example-version">
                  <div class="example-version-label">Inline</div>
                  <pre class="example-code"><code><span class="syn-dim">$</span> ilo <span class="syn-s">'sf url:t>t;r=$url;??r "fallback"'</span> "https://api.example.com/data"
<span class="syn-result">fallback</span></code></pre>
                </div>
                <div class="example-version">
                  <div class="example-version-label">File</div>
                  <pre class="example-code"><code><span class="syn-fn">safe</span> <span class="syn-p">url</span><span class="syn-t">:text</span> <span class="syn-op">&gt;</span> <span class="syn-t">text</span>
  <span class="syn-p">r</span> = <span class="syn-fn">get</span> <span class="syn-p">url</span>
  <span class="syn-op">??</span> <span class="syn-p">r</span> <span class="syn-s">"fallback"</span>
</code></pre>
                  <pre class="example-output"><code><span class="syn-dim">$</span> ilo safe.ilo safe "https://api.example.com/data"
<span class="syn-result">fallback</span></code></pre>
                </div>
              </div>
              <div class="example-desc">HTTP GET with nil-coalesce fallback. Errors are values, not exceptions.</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PHILOSOPHY -->
    <section class="philosophy" data-animate>
      <div class="container">
        <div class="philosophy-inner">
          <p class="philosophy-quote">
            <em>ilo</em> is <a href="https://tokipona.org/" target="_blank" rel="noopener" class="philosophy-link">Toki Pona</a> for &ldquo;tool&rdquo;. ~120 words for all of human expression. ilo does the same for machine programmers.
          </p>
          <div class="principles">
            <span class="principle">Token-conservative</span>
            <span class="principle">Constrained</span>
            <span class="principle">Self-contained</span>
            <span class="principle">Language-agnostic</span>
            <span class="principle">Graph-native</span>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="final-cta" data-animate>
      <div class="container">
        <p class="cta-statement">Make your agents more efficient.</p>
        <div class="hero-actions">
          <a href="/docs/introduction/" class="btn btn-primary">
            Get Started
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="https://github.com/ilo-lang/ilo" target="_blank" rel="noopener" class="btn btn-outline">
            View on GitHub
          </a>
        </div>
      </div>
    </section>
  </main>

  <!-- FOOTER -->
  <footer>
    <div class="container footer-inner">
      <div class="footer-left">
        <span class="footer-logo">ilo</span>
        <a href="https://github.com/ilo-lang/ilo/blob/main/LICENSE" target="_blank" rel="noopener" class="footer-copy">MIT License</a>
      </div>
      <div class="footer-links">
        <a href="/docs/introduction/">Docs</a>
        <a href="https://github.com/ilo-lang/ilo" target="_blank" rel="noopener">GitHub</a>
        <a href="https://www.npmjs.com/package/ilo-lang" target="_blank" rel="noopener">npm</a>
        <a href="https://crates.io/crates/ilo" target="_blank" rel="noopener">crates.io</a>
        <a href="https://www.reddit.com/r/ilolang/" target="_blank" rel="noopener">Reddit</a>
        <a href="/contact/">Contact</a>
        <a href="https://github.com/ilo-lang/ilo/blob/main/PRIVACY.md" target="_blank" rel="noopener">Privacy</a>
      </div>
    </div>
  </footer>

</body>
</html>

<style>
  /* ===== RESET ===== */
  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  /* ===== VARIABLES ===== */
  :root {
    --bg: #08080c;
    --bg-raised: #0e0e14;
    --bg-card: #111118;
    --bg-card-hover: #16161f;
    --border: rgba(255, 255, 255, 0.06);
    --border-hover: rgba(245, 158, 11, 0.25);
    --text: #e4e4e8;
    --text-muted: #9a9ab0;
    --text-dim: #6e6e88;
    --accent: #f59e0b;
    --accent-bright: #fbbf24;
    --accent-dim: rgba(245, 158, 11, 0.08);
    --font-display: 'Bricolage Grotesque', system-ui, sans-serif;
    --font-body: 'Bricolage Grotesque', system-ui, sans-serif;
    --font-mono: 'JetBrains Mono', ui-monospace, monospace;
    --font-serif: 'Instrument Serif', Georgia, serif;
    --container: 1100px;
  }

  /* ===== BASE ===== */
  html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    font-variant-ligatures: none;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    overflow-x: hidden;
  }

  .container {
    max-width: var(--container);
    margin: 0 auto;
    padding: 0 24px;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  /* ===== NAV ===== */
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    background: rgba(8, 8, 12, 0.8);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: 0 24px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.4rem;
    color: var(--accent);
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .nav-links a {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-muted);
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: var(--text);
  }

  .nav-github {
    display: flex;
    align-items: center;
    gap: 0.3em;
  }

  .nav-cta {
    background: var(--accent) !important;
    color: #000 !important;
    padding: 6px 16px;
    border-radius: 6px;
    font-weight: 600 !important;
    font-size: 1rem !important;
    transition: filter 0.2s;
  }

  .nav-cta:hover {
    filter: brightness(1.15);
    color: #000 !important;
  }

  /* ===== HERO ===== */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding-top: 60px;
  }

  .hero-glow {
    position: absolute;
    top: 15%;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 500px;
    background: radial-gradient(ellipse, rgba(245, 158, 11, 0.07) 0%, rgba(245, 158, 11, 0.02) 40%, transparent 70%);
    pointer-events: none;
    animation: glowPulse 6s ease-in-out infinite;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 32px 32px;
    mask-image: radial-gradient(ellipse 60% 50% at 50% 40%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 60% 50% at 50% 40%, black 20%, transparent 70%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    text-align: center;
    z-index: 1;
  }

  .hero-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--accent);
    background: var(--accent-dim);
    border: 1px solid rgba(245, 158, 11, 0.15);
    padding: 6px 16px;
    border-radius: 100px;
    margin-bottom: 2rem;
    letter-spacing: 0.02em;
    animation: fadeInUp 0.8s ease forwards;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(7rem, 18vw, 14rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 0.9;
    margin-bottom: 1.5rem;
    color: var(--text);
    animation: heroReveal 1s ease forwards;
  }

  .hero-tagline {
    font-size: clamp(1.05rem, 2.2vw, 1.3rem);
    color: var(--text-muted);
    max-width: 560px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
    font-weight: 400;
    animation: fadeInUp 0.8s ease 0.2s forwards;
    opacity: 0;
  }

  .hero-tagline-accent {
    color: var(--text);
    font-weight: 500;
  }

  .install-tabs {
    animation: fadeInUp 0.8s ease 0.35s forwards;
    opacity: 0;
  }

  .tab-buttons {
    display: flex;
    justify-content: center;
    gap: 2px;
    margin-bottom: 0;
  }

  .tab-btn {
    background: transparent;
    border: 1px solid var(--border);
    border-bottom: none;
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 8px 16px;
    cursor: pointer;
    transition: color 0.2s, background 0.2s;
    border-radius: 6px 6px 0 0;
  }

  .tab-btn:hover {
    color: var(--text-muted);
  }

  .tab-btn.active {
    background: var(--bg-raised);
    color: var(--accent);
    border-color: var(--border);
  }

  .hero-terminal {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: 0 0 8px 8px;
    padding: 14px 18px;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    cursor: pointer;
    transition: border-color 0.3s, box-shadow 0.3s;
    max-width: 600px;
    margin: 0 auto;
  }

  .hero-terminal:hover {
    border-color: var(--border-hover);
    box-shadow: 0 0 30px rgba(245, 158, 11, 0.06);
  }

  .terminal-prompt {
    color: var(--text-dim);
    user-select: none;
  }

  .terminal-text {
    color: var(--accent-bright);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
    min-width: 0;
  }

  .terminal-copy {
    background: none;
    border: none;
    color: var(--text-dim);
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
    transition: color 0.2s;
  }

  .terminal-copy:hover {
    color: var(--accent);
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-top: 2rem;
    flex-wrap: wrap;
    animation: fadeInUp 0.8s ease 0.5s forwards;
    opacity: 0;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 8px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .btn-primary {
    background: var(--accent);
    color: #000;
  }

  .btn-primary:hover {
    filter: brightness(1.15);
    transform: translateY(-1px);
  }

  .btn-outline {
    border: 1px solid var(--border);
    color: var(--text-muted);
  }

  .btn-outline:hover {
    border-color: var(--border-hover);
    color: var(--accent);
  }

  /* ===== STATS ===== */
  .stats {
    padding: 5rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .stats-grid {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .stat {
    text-align: center;
    min-width: 160px;
  }

  .stat-number {
    font-family: var(--font-display);
    font-size: clamp(3rem, 6vw, 4rem);
    font-weight: 800;
    color: var(--accent);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .stat-label {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text);
    margin-top: 0.5rem;
  }

  .stat-context {
    font-size: 0.8rem;
    color: var(--text-dim);
    margin-top: 0.25rem;
    font-family: var(--font-mono);
  }

  .stat-divider {
    width: 1px;
    height: 48px;
    background: var(--border);
  }

  /* ===== SECTIONS (shared) ===== */
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    text-align: center;
    margin-bottom: 0.5rem;
  }

  .section-subtitle {
    text-align: center;
    color: var(--text-muted);
    font-size: 1.05rem;
    margin-bottom: 3rem;
  }

  /* ===== CODE COMPARISON ===== */
  .comparison {
    padding: 6rem 0;
  }

  .compare-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .code-window {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--bg-raised);
  }

  .code-window--muted {
    opacity: 0.7;
    transition: opacity 0.3s;
  }

  .code-window--muted:hover {
    opacity: 0.9;
  }

  .code-window--highlight {
    border-color: rgba(245, 158, 11, 0.2);
    box-shadow: 0 0 40px rgba(245, 158, 11, 0.04);
  }

  .code-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.015);
  }

  .window-dots {
    display: flex;
    gap: 6px;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    opacity: 0.5;
  }

  .dot--red { background: #ff5f57; }
  .dot--yellow { background: #febc2e; }
  .dot--green { background: #28c840; }

  .code-filename {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    flex: 1;
  }

  .code-badge {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-dim);
    background: rgba(255, 255, 255, 0.04);
    padding: 3px 10px;
    border-radius: 100px;
  }

  .code-badge--accent {
    color: var(--accent);
    background: var(--accent-dim);
  }

  .code-body {
    padding: 20px;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    line-height: 1.8;
    overflow-x: auto;
    background: transparent;
    color: var(--text);
  }

  .code-body code {
    font-family: inherit;
  }

  /* ===== SYNTAX COLORS ===== */
  .syn-kw { color: #c792ea; }
  .syn-fn { color: #82aaff; }
  .syn-p { color: #d6d6e0; }
  .syn-t { color: #89ddff; }
  .syn-s { color: #c3e88d; }
  .syn-op { color: #f59e0b; }
  .syn-cm { color: #546e7a; }

  /* ===== FEATURES ===== */
  .features {
    padding: 6rem 0;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .feature-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px;
    transition: border-color 0.3s, transform 0.2s, box-shadow 0.3s;
  }

  .feature-card:hover {
    border-color: var(--border-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
  }

  .feature-card--wide {
    grid-column: span 1;
  }

  .feature-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 8px;
  }

  .feature-card h3 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 8px;
    letter-spacing: -0.01em;
  }

  .feature-card p {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .feature-code {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    background: rgba(0, 0, 0, 0.25);
    padding: 10px 14px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    gap: 12px;
    overflow-x: auto;
  }

  .feature-code code {
    font-family: inherit;
    white-space: nowrap;
  }

  .feature-code-note {
    color: var(--text-dim);
    font-size: 0.75rem;
    white-space: nowrap;
  }

  .feature-code--error code {
    color: #f87171;
  }

  /* ===== EXAMPLES ===== */
  .examples {
    padding: 6rem 0;
  }

  .examples-tabs {
    max-width: 1060px;
    margin: 0 auto;
    display: flex;
    gap: 0;
  }

  .examples-tab-buttons {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex-shrink: 0;
    border-right: 1px solid var(--border);
    padding-right: 0;
  }

  .examples-tab-btn {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text-muted);
    background: none;
    border: none;
    padding: 10px 20px;
    cursor: pointer;
    border-right: 2px solid transparent;
    margin-right: -1px;
    transition: color 0.2s, border-color 0.2s;
    letter-spacing: 0.02em;
    text-align: left;
    white-space: nowrap;
  }

  .examples-tab-btn:hover {
    color: var(--text);
  }

  .examples-tab-btn.active {
    color: var(--accent);
    border-right-color: var(--accent);
  }

  .examples-panel {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: none;
    border-radius: 0 12px 12px 0;
    padding: 28px;
    flex: 1;
    min-width: 0;
  }

  .example-pane {
    display: none;
  }

  .example-pane.active {
    display: block;
  }

  .example-compare {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 16px;
  }

  .example-version {
    position: relative;
  }

  .example-version-label {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-bottom: none;
    padding: 4px 12px;
    border-radius: 6px 6px 0 0;
    margin-bottom: 0;
  }

  .example-code {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    line-height: 1.7;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.06);
    padding: 16px;
    border-radius: 0 6px 6px 6px;
    overflow-x: auto;
    white-space: pre-wrap;
    word-break: break-all;
    margin-bottom: 0;
  }

  .example-code code {
    font-family: inherit;
  }

  .example-output {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    line-height: 1.6;
    background: rgba(0, 0, 0, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-top: 1px dashed rgba(255, 255, 255, 0.08);
    padding: 12px 16px;
    border-radius: 0 0 6px 6px;
    margin-top: -1px;
    margin-bottom: 0;
    overflow-x: auto;
  }

  .example-output code {
    font-family: inherit;
  }

  .syn-dim { color: var(--text-dim); }
  .syn-result { color: var(--accent); font-weight: 500; }

  .example-readable {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-dim);
    padding: 12px 18px;
    border-radius: 6px;
    border: 1px dashed var(--border);
    margin-bottom: 12px;
    white-space: pre;
    overflow-x: auto;
  }

  .example-readable-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 6px;
  }

  .example-desc {
    font-size: 0.95rem;
    color: var(--text-dim);
    line-height: 1.5;
  }

  /* ===== PHILOSOPHY ===== */
  .philosophy {
    padding: 6rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .philosophy-inner {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }

  .philosophy-quote {
    font-family: var(--font-serif);
    font-size: clamp(1.3rem, 3vw, 1.7rem);
    line-height: 1.7;
    color: var(--text-muted);
    margin-bottom: 2.5rem;
    font-style: italic;
  }

  .philosophy-quote em {
    color: var(--text);
    font-style: italic;
  }

  .philosophy-link {
    color: var(--text-muted);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(255,255,255,0.15);
    transition: color 0.2s, text-decoration-color 0.2s;
  }

  .philosophy-link:hover {
    color: var(--text);
    text-decoration-color: var(--accent);
  }

  .principles {
    display: flex;
    gap: 8px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .principle {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-muted);
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 6px 14px;
    border-radius: 100px;
    transition: border-color 0.2s, color 0.2s;
  }

  .principle:hover {
    border-color: var(--border-hover);
    color: var(--accent);
  }

  /* ===== FINAL CTA ===== */
  .final-cta {
    padding: 6rem 0;
    text-align: center;
  }

  .cta-statement {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2.2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 2rem;
    color: var(--text);
  }

  /* ===== FOOTER ===== */
  footer {
    border-top: 1px solid var(--border);
    padding: 2rem 0;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .footer-logo {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.1rem;
    color: var(--accent);
  }

  .footer-copy {
    font-size: 1rem;
    color: var(--text-dim);
    transition: color 0.2s;
  }
  .footer-copy:hover {
    color: var(--accent);
  }

  .footer-links {
    display: flex;
    gap: 20px;
  }

  .footer-links a {
    font-size: 1rem;
    color: var(--text-dim);
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: var(--accent);
  }

  /* ===== ANIMATIONS ===== */
  @keyframes heroReveal {
    from {
      opacity: 0;
      letter-spacing: -0.06em;
      filter: blur(6px);
    }
    to {
      opacity: 1;
      letter-spacing: -0.04em;
      filter: blur(0);
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes glowPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }

  /* Scroll animations — progressive enhancement: visible by default, animated only when JS adds .animate-ready */
  .animate-ready [data-animate] {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .animate-ready [data-animate].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .compare-grid {
      grid-template-columns: 1fr;
    }

    .feature-grid {
      grid-template-columns: 1fr;
    }

    .examples-tabs {
      flex-direction: column;
    }

    .examples-tab-buttons {
      flex-direction: row;
      flex-wrap: wrap;
      border-right: none;
      border-bottom: 1px solid var(--border);
    }

    .examples-tab-btn {
      padding: 8px 14px;
      font-size: 0.72rem;
      border-right: none;
      border-bottom: 2px solid transparent;
      margin-right: 0;
      margin-bottom: -1px;
    }

    .examples-tab-btn.active {
      border-right-color: transparent;
      border-bottom-color: var(--accent);
    }

    .examples-panel {
      border-left: 1px solid var(--border);
      border-radius: 0 0 12px 12px;
    }

    .stats-grid {
      gap: 2rem;
    }

    .stat-divider {
      display: none;
    }

    .hero-title {
      font-size: clamp(5rem, 20vw, 8rem);
    }

    .nav-links a:not(.nav-cta):not(.nav-github) {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .hero-terminal {
      font-size: 0.85rem;
      padding: 10px 14px;
    }
  }

  /* Feature grid: 3 columns for the bottom row on wider screens */
  @media (min-width: 769px) {
    .feature-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    /* Make the bottom 4 cards into a 4-column row? No, keep 2-col but vary */
  }

  @media (min-width: 1024px) {
    .feature-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<script>
  // Tab switching
  const tabBtns = document.querySelectorAll('.tab-btn');
  const cmdTexts = document.querySelectorAll('.terminal-text[data-cmd]');
  const prompt = document.querySelector('.terminal-prompt') as HTMLElement;
  let activeTab = 'mac';

  const prompts: Record<string, string> = { mac: '$', windows: '>', claude: '>' };
  const commands: Record<string, string> = {
    mac: 'curl -fsSL https://raw.githubusercontent.com/ilo-lang/ilo/main/install.sh | sh',
    windows: 'irm https://raw.githubusercontent.com/ilo-lang/ilo/main/install.ps1 | iex',
    claude: '/plugin marketplace add ilo-lang/ilo && /plugin install ilo-lang/ilo',
  };

  tabBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tab = (btn as HTMLElement).dataset.tab!;
      activeTab = tab;
      tabBtns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      cmdTexts.forEach((t) => {
        (t as HTMLElement).style.display = (t as HTMLElement).dataset.cmd === tab ? '' : 'none';
      });
      if (prompt) prompt.textContent = prompts[tab] || '$';
    });
  });

  // Copy to clipboard
  const copyBtn = document.getElementById('copy-btn');
  const terminal = document.getElementById('install-cmd');

  function handleCopy() {
    navigator.clipboard.writeText(commands[activeTab] || commands.mac);
    const iconCopy = copyBtn?.querySelector('.icon-copy') as HTMLElement;
    const iconCheck = copyBtn?.querySelector('.icon-check') as HTMLElement;
    if (iconCopy && iconCheck) {
      iconCopy.style.display = 'none';
      iconCheck.style.display = 'block';
      setTimeout(() => {
        iconCopy.style.display = 'block';
        iconCheck.style.display = 'none';
      }, 2000);
    }
  }

  copyBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    handleCopy();
  });
  terminal?.addEventListener('click', handleCopy);

  // Examples tab switching
  document.querySelectorAll('.examples-tab-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const example = (btn as HTMLElement).dataset.example!;
      document.querySelectorAll('.examples-tab-btn').forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      document.querySelectorAll('.example-pane').forEach((p) => {
        p.classList.toggle('active', (p as HTMLElement).dataset.examplePane === example);
      });
    });
  });

  // Scroll animations — enable only after JS is ready
  document.documentElement.classList.add('animate-ready');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );

  document.querySelectorAll('[data-animate]').forEach((el) => observer.observe(el));
</script>


---
// Override for Starlight's Head component.
// Renders the standard Starlight head tags, then injects OG image,
// twitter handles, favicons, and webmanifest that Starlight omits.
const { head, id } = Astro.locals.starlightRoute;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://ilo-lang.ai';
// Per-doc OG image generated by src/pages/og/[...slug].png.ts
const ogImage = `${siteUrl}/og/${id}.png`;
---

{head.map(({ tag: Tag, attrs, content }) => <Tag {...attrs} set:html={content} />)}

<!-- OG image (per-doc) -->
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

<!-- Twitter -->
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:site" content="@danielmorris" />
<meta name="twitter:creator" content="@danielmorris" />

<!-- Author -->
<meta name="author" content="Daniel John Morris" />

<!-- Favicons -->
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="shortcut icon" href="/favicon.ico" />
<link rel="manifest" href="/site.webmanifest" />

---
---

<starlight-theme-select>
	<button type="button" aria-label={Astro.locals.t('themeSelect.accessibleLabel')} class="theme-toggle">
		<template class="icon-dark">
			<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
		</template>
		<template class="icon-light">
			<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
		</template>
		<template class="icon-auto">
			<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" transform="scale(0.35) translate(24, 10)" stroke-width="4"/></svg>
		</template>
		<span class="icon-slot"></span>
		<span class="theme-hint"></span>
	</button>
</starlight-theme-select>

{/* Inlined to avoid FOUC. Uses global scope from ThemeProvider.astro */}
<script is:inline>
	StarlightThemeProvider.updatePickers();
</script>

<script>
	type Theme = 'auto' | 'dark' | 'light';

	const storageKey = 'starlight-theme';
	const cycle: Theme[] = ['dark', 'light', 'auto'];
	const hints: Record<Theme, string> = { dark: 'Dark', light: 'Light', auto: 'Auto' };

	const parseTheme = (theme: unknown): Theme =>
		theme === 'auto' || theme === 'dark' || theme === 'light' ? theme : 'auto';

	const loadTheme = (): Theme =>
		parseTheme(typeof localStorage !== 'undefined' && localStorage.getItem(storageKey));

	function storeTheme(theme: Theme): void {
		if (typeof localStorage !== 'undefined') {
			localStorage.setItem(storageKey, theme === 'light' || theme === 'dark' ? theme : '');
		}
	}

	const getPreferredColorScheme = (): Theme =>
		matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';

	function updateIcons(theme: Theme): void {
		document.querySelectorAll<HTMLElement>('starlight-theme-select').forEach((root) => {
			const slot = root.querySelector('.icon-slot');
			const hint = root.querySelector('.theme-hint');
			const template = root.querySelector<HTMLTemplateElement>(`.icon-${theme}`);
			if (slot && template) {
				// Clear existing icon and append from template (safe DOM method)
				while (slot.firstChild) slot.firstChild.remove();
				slot.appendChild(template.content.cloneNode(true));
			}
			if (hint) {
				hint.textContent = hints[theme];
			}
		});
	}

	function onThemeChange(theme: Theme): void {
		StarlightThemeProvider.updatePickers(theme);
		document.documentElement.dataset.theme = theme === 'auto' ? getPreferredColorScheme() : theme;
		storeTheme(theme);
		updateIcons(theme);
	}

	matchMedia('(prefers-color-scheme: light)').addEventListener('change', () => {
		if (loadTheme() === 'auto') onThemeChange('auto');
	});

	class StarlightThemeSelect extends HTMLElement {
		constructor() {
			super();
			const theme = loadTheme();
			onThemeChange(theme);
			this.querySelector('button')?.addEventListener('click', () => {
				const current = loadTheme();
				const next = cycle[(cycle.indexOf(current) + 1) % cycle.length];
				onThemeChange(next);
			});
		}
	}
	customElements.define('starlight-theme-select', StarlightThemeSelect);
</script>

<style>
	.theme-toggle {
		display: flex;
		align-items: center;
		gap: 0.375rem;
		padding: 0.25rem 0.5rem;
		border: 0;
		border-radius: 0.375rem;
		background: transparent;
		color: var(--sl-color-gray-3);
		cursor: pointer;
		transition: color 0.15s ease, background-color 0.15s ease;
		font-family: var(--sl-font);
		font-size: var(--sl-text-xs);
	}
	.theme-toggle:hover {
		color: var(--sl-color-gray-1);
		background: var(--sl-color-gray-6);
	}
	.theme-hint {
		opacity: 0.7;
	}
</style>
